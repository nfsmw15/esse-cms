Options -Indexes
DirectorySlash Off

# local.php is require'd internally by index.php — never meant to be requested directly.
<Files "local.php">
    Require all denied
</Files>

RewriteEngine On

# Static files (public assets) are served directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Everything else goes through index.php
RewriteRule ^ index.php [L]
