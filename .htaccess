Options -Indexes
DirectorySlash Off

# local.php is require'd internally by index.php — never meant to be requested directly.
<Files "local.php">
    Require all denied
</Files>

# Static files (images, CSS, JS, uploads) bypass index.php and therefore never pass through
# SecurityHeaders::send() — set nosniff here too, so it applies regardless of route.
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
</IfModule>

RewriteEngine On

# Static files (public assets) are served directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Everything else goes through index.php
RewriteRule ^ index.php [L]
